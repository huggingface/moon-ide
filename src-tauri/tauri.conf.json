{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "moon-ide",
	"version": "0.0.0",
	"identifier": "dev.moon-ide.desktop",
	"build": {
		"beforeDevCommand": "bun run dev:vite",
		"beforeBuildCommand": "bun run build:vite",
		"devUrl": "http://localhost:1420",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "moon-ide",
				"width": 1280,
				"height": 800,
				"minWidth": 800,
				"minHeight": 500,
				"resizable": true,
				"fullscreen": false,
				"decorations": true,
				"transparent": false
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": ["**"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico", "icons/icon.png"],
		"category": "DeveloperTool",
		"shortDescription": "Team-specialized IDE",
		"longDescription": "moon-ide — a team-specialized IDE built around Tauri, Svelte, and a Rust core."
	}
}
