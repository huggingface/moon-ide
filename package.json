{
	"name": "moon-ide",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tauri dev",
		"dev:vite": "vite",
		"build": "tauri build",
		"build:vite": "vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"fmt:js": "oxfmt --ignore-path .gitignore && prettier --write \"**/*.svelte\"",
		"fmt:js:check": "oxfmt --ignore-path .gitignore --check && prettier --check \"**/*.svelte\"",
		"fmt:rust": "cargo fmt --all",
		"fmt:rust:check": "cargo fmt --all -- --check",
		"fmt": "bun run fmt:js && bun run fmt:rust",
		"fmt:check": "bun run fmt:js:check && bun run fmt:rust:check",
		"lint:js": "oxlint --type-aware",
		"lint:js:fix": "oxlint --type-aware --fix",
		"lint:rust": "cargo clippy --workspace --exclude moon-desktop --all-targets -- -D warnings",
		"lint": "bun run lint:js && bun run lint:rust",
		"lint:fix": "bun run lint:js:fix && bun run lint:rust",
		"check:ts": "tsgo --noEmit",
		"check:svelte": "svelte-check --tsconfig ./tsconfig.json",
		"check:rust": "cargo check --workspace --exclude moon-desktop",
		"check": "bun run check:ts && bun run check:svelte && bun run check:rust",
		"test:rust": "cargo test --workspace --exclude moon-desktop",
		"test": "bun run test:rust",
		"prepare": "husky"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/lang-rust": "^6.0.2",
		"@codemirror/language": "^6.12.3",
		"@codemirror/legacy-modes": "^6.5.2",
		"@codemirror/lint": "^6.9.5",
		"@codemirror/search": "^6.7.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.1",
		"@pierre/trees": "^1.0.0-beta.3",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-dialog": "^2.7.0",
		"codemirror": "^6.0.2",
		"dompurify": "^3.4.1",
		"markdown-it": "^14.1.1"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tauri-apps/cli": "^2.10.1",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.0.0",
		"@typescript/native-preview": "^7.0.0-dev.20260426.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"oxlint-tsgolint": "^0.22.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"typescript": "^5.9.3",
		"vite": "^8.0.10"
	}
}
